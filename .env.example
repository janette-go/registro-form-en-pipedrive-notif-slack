# Pipedrive
PIPEDRIVE_API_TOKEN=your_pipedrive_api_token_here
PIPEDRIVE_PIPELINE_NAME=custodia
PIPEDRIVE_STAGE_NAME=prospeccion
PIPEDRIVE_GCLID_FIELD_KEY=hash_del_campo_personalizado_gclid
PIPEDRIVE_UTM_SOURCE_FIELD_KEY=hash_del_campo_utm_source
PIPEDRIVE_UTM_CAMPAIGN_FIELD_KEY=hash_del_campo_utm_campaign
PIPEDRIVE_UTM_MEDIUM_FIELD_KEY=hash_del_campo_utm_medium
PIPEDRIVE_UTM_TERM_FIELD_KEY=hash_del_campo_utm_term
PIPEDRIVE_UTM_CONTENT_FIELD_KEY=hash_del_campo_utm_content
PIPEDRIVE_CONTACT_REASON_FIELD_KEY=hash_del_campo_contact_reason
PIPEDRIVE_DUDAS_COMENTARIOS_FIELD_KEY=hash_del_campo_dudas_comentarios
PIPEDRIVE_UTM_SOURCE_DEAL_FIELD_KEY=hash_del_campo_origen_trato

# Slack (Incoming Webhook — el canal ya está definido en la URL del webhook)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Servidor
PORT=3000

# Google Ads Offline Conversions
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token_here
GOOGLE_ADS_CLIENT_ID=your_oauth2_client_id_here
GOOGLE_ADS_CLIENT_SECRET=your_oauth2_client_secret_here
GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token_here
GOOGLE_ADS_CUSTOMER_ID=123-456-7890
GOOGLE_ADS_CONVERSION_ACTION_ID=your_conversion_action_id_here

# Deshabilitar notificaciones a Slack (útil para pruebas locales)
DISABLE_SLACK=false

# Seguridad (opcional): clave secreta para verificar que el webhook viene de Webflow
WEBHOOK_SECRET=your_optional_secret_here
